{
  "manifest_version": 3,
  "name": "Tab Domain Grouper",
  "version": "0.1.0",
  "description": "Group tabs by domain with stable group colors.",
  "minimum_chrome_version": "89",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],
  "action": {
    "default_title": "Tab Domain Grouper",
    "default_popup": "popup.html"
  },
  "commands": {
    "GROUP_NOW": {
      "suggested_key": {
        "default": "Ctrl+G",
        "mac": "Command+G"
      },
      "description": "Group tabs in focused window now"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service-worker.js"
  }
}
